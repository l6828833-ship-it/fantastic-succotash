# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string. Use your Supabase database URL.
# In Supabase: Project Settings -> Database -> Connection string.
#   - App runtime (Railway): use the "Transaction" pooler (port 6543), e.g.
#       postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#   - Migrations (pnpm db:push): use the "Session" pooler (port 5432) or the
#       direct connection, since the transaction pooler does not support DDL well.
# TLS is required by Supabase (enabled automatically). Append ?sslmode=disable
# only for a local Postgres without TLS.
DATABASE_URL=postgresql://postgres.your-ref:your-password@aws-0-your-region.pooler.supabase.com:6543/postgres

# Secret used to sign session cookies (JWT). Generate one with:
#   openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string

# ─── GitHub OAuth ────────────────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
#   - Homepage URL:               https://your-app.up.railway.app
#   - Authorization callback URL: https://your-app.up.railway.app/api/oauth/callback
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# ─── Optional ────────────────────────────────────────────────────────────────

# Grant the "admin" role to a specific GitHub account on sign-in.
# Use your GitHub username:
OWNER_GITHUB_LOGIN=your-github-username
# ...or, alternatively, the internal user id (format: github:<numeric-id>):
# OWNER_OPEN_ID=github:1234567

# Force the public base URL used to build OAuth redirect URIs. Normally derived
# from the request headers; set this only if redirects resolve to the wrong host
# (e.g. behind certain proxies). No trailing slash.
# APP_BASE_URL=https://your-app.up.railway.app

# Port the server listens on (Railway sets this automatically).
# PORT=3000

# ─── AI features ─────────────────────────────────────────────────────────────
# The app uses gpt-4o-mini for AI replies and the playground. Provide your own
# OpenAI API key to call OpenAI directly (recommended for standalone deploys):
OPENAI_API_KEY=sk-your-openai-api-key
# Alternatively, point at any OpenAI-compatible gateway:
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=


# ─── Email (Brevo — recommended) ─────────────────────────────────────────────
# Used for sign-up verification codes (OTP) and transactional/campaign email.
# Brevo's HTTP API is preferred because it works on hosts that block SMTP ports
# (e.g. Railway). Create a key in Brevo: account menu -> SMTP & API -> API Keys.
# EMAIL_FROM must be a sender you've verified in Brevo (Senders & Domains).
BREVO_API_KEY=xkeysib-your-brevo-api-key
EMAIL_FROM=hello@yourdomain.com
EMAIL_FROM_NAME=Chatrico

# ─── Email / SMTP (fallback, optional) ───────────────────────────────────────
# Only used when BREVO_API_KEY is not set. Works with any SMTP provider. Note
# that some hosts (Railway) block outbound SMTP ports — prefer Brevo above.
# Example (Brevo SMTP relay): host=smtp-relay.brevo.com, port=587 (or 2525)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
# true/1/yes to use TLS-on-connect (smtps). Defaults to true only for port 465.
# SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
